{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "lib": ["DOM", "ES2021"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2021",
    "types": []
  },
  "include": ["src/**/*.ts"]
}
